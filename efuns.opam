# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Emacs clone in OCaml"
description: """
Efuns is an Emacs-like text editor written in OCaml with a GTK/Cairo GUI
and semantic code highlighting via semgrep parsers.

For more information see https://github.com/aryx/fork-efuns
"""
maintainer: ["Yoann Padioleau <yoann.padioleau@gmail.com>"]
authors: ["Yoann Padioleau <yoann.padioleau@gmail.com>"]
license: "LGPL-2.1-only WITH OCaml-LGPL-linking-exception"
homepage: "https://github.com/aryx/fork-efuns"
bug-reports: "https://github.com/aryx/fork-efuns/issues"
depends: [
  "dune" {>= "2.7" & >= "3.7"}
  "lablgtk"
  "cairo2-gtk"
  "cairo2-pango"
  "logs"
  "ANSITerminal"
  "alcotest"
  "alcotest-lwt"
  "atdgen"
  "bos"
  "cmdliner" {>= "1.3.0" & < "2.0.0"}
  "digestif"
  "fmt"
  "fpath"
  "git"
  "lwt"
  "lwt_ppx"
  "memtrace"
  "ocolor"
  "ocamlgraph"
  "pcre"
  "pcre2"
  "ppx_deriving"
  "ppx_deriving_yojson"
  "ppx_hash"
  "ppx_inline_test"
  "ppx_sexp_conv"
  "ppxlib"
  "re"
  "semver"
  "sexplib"
  "testo"
  "timedesc"
  "trace"
  "opentelemetry" {< "0.11"}
  "opentelemetry-client-ocurl" {< "0.11"}
  "ambient-context-lwt"
  "uri"
  "uuidm"
  "yojson"
  "menhir" {= "20230608"}
  "parmap"
  "tsort"
  "visitors"
  "yaml"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/aryx/fork-efuns.git"
